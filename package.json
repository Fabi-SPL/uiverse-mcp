{
  "name": "uiverse-mcp",
  "version": "1.0.0",
  "description": "MCP server for Uiverse.io — browse, search, and fetch 3,800+ open-source UI components (buttons, cards, loaders, inputs, and more) directly in Claude Code, Cursor, Codex, or any MCP-compatible agent.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "uiverse-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "refresh-cache": "tsx src/refresh-cli.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fuse.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": {
    "name": "Fabi-SPL",
    "url": "https://github.com/Fabi-SPL"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Fabi-SPL/uiverse-mcp.git"
  },
  "homepage": "https://github.com/Fabi-SPL/uiverse-mcp#readme",
  "bugs": {
    "url": "https://github.com/Fabi-SPL/uiverse-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "uiverse",
    "uiverse-io",
    "ui-components",
    "css",
    "tailwind",
    "buttons",
    "cards",
    "loaders",
    "design",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "ai-tools",
    "developer-tools"
  ]
}
